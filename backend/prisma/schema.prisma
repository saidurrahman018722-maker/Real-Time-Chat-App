// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

enum OtpType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  TWO_FACTOR_AUTH
}

model User {
  id                String    @id @default(uuid())
  name              String
  email             String    @unique
  password          String
  verified          Boolean   @default(false)
  profilePic        String?
  verifyToken       String?   @unique
  verifyTokenExpiry DateTime?
  resetToken        String?   @unique
  resetTokenExpiry  DateTime?
  lastSeen          DateTime  @default(now())
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  opts             Otp[]
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  
  conversations    Conversation[] @relation("UserConversations")
  contacts         Contact[]      @relation("ContactOwner")
  savedAsContact   Contact[]      @relation("ContactUser")
}

model Otp {
  id        String   @id @default(uuid())
  code      String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      OtpType  @default(EMAIL_VERIFICATION)
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
}

model Conversation {
  id            String    @id @default(uuid())
  isGroup       Boolean   @default(false)
  groupName     String?
  groupPhoto    String?
  participants  User[]    @relation("UserConversations")
  messages      Message[]
  lastMessageId String?
  updatedAt     DateTime  @updatedAt
  createdAt     DateTime  @default(now())
  
  deletedBy     String[]  @default([])
}

model Contact {
  id        String   @id @default(uuid())
  ownerId   String
  owner     User     @relation("ContactOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("ContactUser", fields: [userId], references: [id], onDelete: Cascade)
  alias     String?
  createdAt DateTime @default(now())

  @@unique([ownerId, userId])
}

model Message {
  id         String @id @default(uuid())
  senderId   String
  receiverId String?
  
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  text  String?
  image String?
  
  status        MessageStatus @default(SENT)
  isDeletedForEveryone Boolean  @default(false)
  deletedBy            String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sender   User  @relation("SentMessages", fields: [senderId], references: [id])
  receiver User? @relation("ReceivedMessages", fields: [receiverId], references: [id])

  @@index([senderId, receiverId])
  @@index([receiverId])
  @@index([conversationId])
}
